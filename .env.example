# Copy to .env and adjust. Real secrets are never committed (.gitignore covers .env).

# HTTP
PORT=8080
APP_ENV=dev

# Session cookie. Keep false for local http; set true behind HTTPS in prod.
COOKIE_SECURE=false

# Database connection.
# For `make dev` (Go runs on your HOST, Postgres in Docker) use localhost:
DATABASE_URL=postgres://ledgerflow:ledgerflow@localhost:5432/ledgerflow?sslmode=disable
# When the backend itself runs INSIDE docker-compose, the DB host is the service name "db":
#   DATABASE_URL=postgres://ledgerflow:ledgerflow@db:5432/ledgerflow?sslmode=disable
